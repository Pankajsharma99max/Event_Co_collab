# Copy to .env and fill in real values. Never commit .env itself.

DATABASE_URL="file:./dev.db"

# --- Sub-path deployment ---
# Empty = run at the root (local dev). "/submit-event" = serve under
# devnovate.co/submit-event via the main site's reverse proxy. Rebuild after changing.
NEXT_PUBLIC_BASE_PATH=""

# --- Auth.js ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=""
# Production only: full public auth URL, e.g. https://devnovate.co/submit-event/api/auth
# AUTH_URL=""

# --- Google OAuth (optional) ---
# Leave blank to disable — the "Continue with Google" button hides itself
# automatically when these aren't set. To enable: Google Cloud Console →
# APIs & Services → Credentials → Create OAuth client ID (Web application),
# authorized redirect URI: <your-domain>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Devnovate.co verification (see src/lib/devnovate-client.ts) ---
DEVNOVATE_API_MOCK="true"

# PREFERRED: no backend changes needed — checks devnovate.co's own public
# event API for this exact Mongo ObjectId in the organizers array.
REQUIRED_DEVNOVATE_ORGANIZER_ID=""

# FALLBACK: only used if the above is blank; requires devnovate-api-patch/ deployed.
DEVNOVATE_API_URL="https://devnovate.co/api/v1/external"
DEVNOVATE_API_KEY=""

# Co-host manager email shown in the wizard's instructions
NEXT_PUBLIC_REQUIRED_COHOST_EMAIL="aviral.lancer@gmail.com"

# Required Luma Host profile ID
REQUIRED_LUMA_HOST_ID="usr-kpQUGVbfViXAj2x"

# --- Admin panel bootstrap ---
# Comma-separated emails auto-promoted to ADMIN role on next sign-in.
ADMIN_EMAILS=""
